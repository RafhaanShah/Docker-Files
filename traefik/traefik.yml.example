# https://doc.traefik.io/traefik/getting-started/configuration-overview/
# https://doc.traefik.io/traefik/reference/static-configuration/file/

global:
  sendAnonymousUsage: false

log:
  level: INFO

entryPoints:
  web:
    address: ":80"
    http:
      middlewares:
        - https-redirect@file
  websecure:
    address: ":443"
    http:
      middlewares:
        - lan-ipallowlist@file
        - https-redirect@file
        - default-headers@file
        - access-control-headers@file
      tls: {} # force any available TLS

api:
  dashboard: true
  insecure: false

providers:
  providersThrottleDuration: 10s
  docker:
    exposedByDefault: false
    endpoint: "tcp://socket-proxy:2375"
    # regex matches service_name followed by . followed by anything
    # e.g. container.lan or container.host.lan
    defaultRule: "HostRegexp(`^{{ index .Labels \"com.docker.compose.service\" }}\\..+`)"
  file:
    directory: /etc/traefik/config
    watch: true

certificatesResolvers:
  leresolver:
    acme:
      email: someone@mail.com
      storage: /etc/traefik/acme.json
      keyType: RSA4096
      dnsChallenge:
        provider: duckdns
        propagation:
          delayBeforeChecks: 120
          disableChecks: true
  cfresolver:
    acme:
      email: someone@mail.com
      storage: /etc/traefik/acme.json
      keyType: RSA4096
      dnsChallenge:
        provider: cloudflare
        propagation:
          delayBeforeChecks: 120
          disableChecks: true

# accepts self signed certificates on internal services
serversTransport:
  insecureSkipVerify: true
